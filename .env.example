# ============================================================
# SATTVAYOGA 365 — Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Firebase project credentials below
# 3. NEVER commit the .env file — it is in .gitignore
# ============================================================

# --- Firebase SDK Credentials ---
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Admin Access Control ---
# Comma-separated list of Google email addresses allowed to access /admin
VITE_ADMIN_EMAILS=your-admin-email@gmail.com,another-admin@gmail.com
